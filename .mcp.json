{
  "name": "pet-care-ai-mcp",
  "description": "**Pet Management Intelligence**",
  "version": "1.0.0",
  "tools": [
    {
      "name": "generate_feeding_schedule",
      "description": "Generate a tailored feeding schedule for a pet.",
      "parameters": {
        "type": "object",
        "properties": {
          "species": {
            "type": "string"
          },
          "breed": {
            "type": "string",
            "nullable": true
          },
          "weight_kg": {
            "type": "number"
          },
          "age_months": {
            "type": "integer"
          },
          "activity_level": {
            "type": "string"
          },
          "special_needs": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true
          }
        },
        "required": [
          "species"
        ]
      }
    },
    {
      "name": "track_vaccinations",
      "description": "Track vaccination status and generate upcoming schedule.",
      "parameters": {
        "type": "object",
        "properties": {
          "species": {
            "type": "string"
          },
          "age_weeks": {
            "type": "integer"
          },
          "vaccinations_given": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true
          },
          "indoor_only": {
            "type": "boolean"
          }
        },
        "required": [
          "species",
          "age_weeks"
        ]
      }
    },
    {
      "name": "identify_breed",
      "description": "Identify likely breed from physical and behavioral characteristics.",
      "parameters": {
        "type": "object",
        "properties": {
          "species": {
            "type": "string"
          },
          "characteristics": {
            "type": "object"
          }
        },
        "required": [
          "species",
          "characteristics"
        ]
      }
    },
    {
      "name": "check_health_symptoms",
      "description": "Check pet health symptoms and get guidance on urgency and next steps.",
      "parameters": {
        "type": "object",
        "properties": {
          "species": {
            "type": "string"
          },
          "symptoms": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "age_months": {
            "type": "integer"
          },
          "additional_info": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "species",
          "symptoms"
        ]
      }
    },
    {
      "name": "get_training_recommendations",
      "description": "Get personalized training recommendations for a pet.",
      "parameters": {
        "type": "object",
        "properties": {
          "species": {
            "type": "string"
          },
          "breed": {
            "type": "string",
            "nullable": true
          },
          "age_months": {
            "type": "integer"
          },
          "issues": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true
          },
          "experience_level": {
            "type": "string"
          }
        },
        "required": [
          "species"
        ]
      }
    }
  ]
}
